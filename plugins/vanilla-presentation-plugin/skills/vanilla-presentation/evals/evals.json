          "type": "grep_present",
          "pattern": "data-step="
        },
        {
          "id": "has-speaker-notes",
          "description": "Speaker notes JSON present",
          "type": "grep_present",
          "pattern": "speakerNotes"
        },
        {
          "id": "has-themes",
          "description": "data-theme attributes on slides",
          "type": "grep_present",
          "pattern": "data-theme="
        },
        {
          "id": "animation-lock",
          "description": "isAnimating flag present",
          "type": "grep_present",
          "pattern": "isAnimating"
        },
        {
          "id": "touch-swipe",
          "description": "Touch swipe support",
          "type": "grep_present",
          "pattern": "touchstart"
        },
        {
          "id": "hash-sync",
          "description": "URL hash sync",
          "type": "grep_present",
          "pattern": "pushState"
        },
        {
          "id": "dataflow-ai-content",
          "description": "DataFlow AI company name present in content",
          "type": "grep_present",
